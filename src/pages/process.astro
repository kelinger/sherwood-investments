---
import Layout from '../layouts/Layout.astro';
const steps = [
  { num: "01", title: "Identify Your Objectives", desc: "We start by understanding your current situation, objectives, and needs. No long questionnaires — just a real conversation." },
  { num: "02", title: "Formulate the Best Strategy", desc: "We develop your personalized financial plan and investment portfolio, tailored specifically to your goals." },
  { num: "03", title: "Select Quality Investments", desc: "Thousands of low-cost investments are analyzed. Only those with the best outlook for your situation are considered." },
  { num: "04", title: "Manage & Update Your Investments", desc: "Your portfolio is continually monitored to reflect changing financial and personal conditions — not just reviewed once a year." },
  { num: "05", title: "Work Closely With You", desc: "Calls are returned the same day. There is never a charge for calls or meetings. You always have direct access to Eric." },
];
---
<Layout title="Our Process" description="Sherwood Investments' proven five-step financial planning process — Redmond, WA.">
  <div class="bg-navy-dark text-white py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold uppercase tracking-widest text-sm font-semibold mb-2">How We Work</p>
      <h1 class="font-serif text-4xl font-bold mb-4">Our Proven Five-Step Process</h1>
      <p class="text-gray-300">"We want you to have financial security, not just securities."</p>
    </div>
  </div>

  <section class="max-w-3xl mx-auto px-4 py-16">
    <div class="space-y-8">
      {steps.map(step => (
        <div class="flex gap-6 items-start">
          <div class="text-gold font-serif text-4xl font-bold w-16 shrink-0 text-right">{step.num}</div>
          <div class="border-l-2 border-gold pl-6 pb-8">
            <h2 class="font-serif text-xl font-bold text-navy mb-2">{step.title}</h2>
            <p class="text-gray-600 leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-navy text-white py-12 px-4 text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="font-serif text-2xl font-bold mb-4">Ready to get started?</h2>
      <a href="/contact" class="bg-gold text-navy-dark px-8 py-3 rounded font-semibold hover:bg-gold-light transition-colors inline-block">
        Improve My Financial Future
      </a>
    </div>
  </section>
</Layout>
