---
import Layout from '../layouts/Layout.astro';
const success = Astro.url.searchParams.get('success');
---
<Layout title="Contact" description="Contact Sherwood Investments — fee-only financial advisor in Redmond, WA. Call 425-898-8989.">
  <div class="relative text-white py-16 px-4 text-center" style="background: linear-gradient(rgba(19,40,64,0.78), rgba(19,40,64,0.78)), url('/banners/contact.jpg') center/cover no-repeat;">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold uppercase tracking-widest text-sm font-semibold mb-2">Get In Touch</p>
      <h1 class="font-serif text-4xl font-bold mb-4">Contact Us</h1>
      <p class="text-gray-300">All calls are returned within one business day. No charge for calls or meetings.</p>
    </div>
  </div>

  {success && (
    <div class="max-w-5xl mx-auto px-4 pt-8">
      <div class="bg-green-50 border border-green-200 text-green-800 rounded-xl px-6 py-4 text-sm font-medium">
        ✓ Thank you! Your message has been sent. Eric will get back to you within one business day.
      </div>
    </div>
  )}

  <section class="max-w-5xl mx-auto px-4 pt-10 pb-2">
    <img src="/mom-on-phone.jpg" alt="" class="w-full max-h-72 object-cover rounded-xl shadow-sm" />
  </section>

  <section class="max-w-5xl mx-auto px-4 py-16 grid grid-cols-1 md:grid-cols-2 gap-12">
    <div>
      <h2 class="font-serif text-2xl font-bold text-navy mb-6">Sherwood Investments</h2>
      <div class="space-y-4 text-gray-600">
        <div>
          <p class="text-xs uppercase tracking-wider text-gold font-semibold mb-1">Address</p>
          <p>23705 NE 61st Street<br />Redmond, WA 98053</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-gold font-semibold mb-1">Phone</p>
          <a href="tel:4258988989" class="text-navy font-semibold hover:text-gold transition-colors text-lg">425-898-8989</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-gold font-semibold mb-1">Email</p>
          <a href="mailto:moreinfo@sherwood-investments.com" class="text-navy hover:text-gold transition-colors">moreinfo@sherwood-investments.com</a>
        </div>
      </div>
    </div>

    <div>
      <h2 class="font-serif text-2xl font-bold text-navy mb-6">Send a Message</h2>
      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
        <input type="hidden" name="access_key" value="1acee27d-03f0-4601-8511-01c57ab13bb6" />
        <input type="hidden" name="subject" value="New Contact Form Submission — Sherwood Investments" />
        <input type="hidden" name="redirect" value="https://sherwood-investments.com/contact?success=true" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="name">Name</label>
          <input type="text" id="name" name="name" required class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Email</label>
          <input type="email" id="email" name="email" required class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="phone">Phone (optional)</label>
          <input type="tel" id="phone" name="phone" class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="message">Message</label>
          <textarea id="message" name="message" rows="4" required class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-navy text-white py-3 rounded-lg font-semibold hover:bg-navy-dark transition-colors">
          Send Message
        </button>
      </form>
    </div>
  </section>
</Layout>
