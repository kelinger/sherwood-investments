---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Resources" description="Investment newsletters, the Letter of Agreement, and partner links from Sherwood Investments.">
  <div class="bg-navy-dark text-white py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold uppercase tracking-widest text-sm font-semibold mb-2">Stay Informed</p>
      <h1 class="font-serif text-4xl font-bold">Resources</h1>
    </div>
  </div>

  <section class="max-w-5xl mx-auto px-4 py-16 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="p-6 border border-gray-100 rounded-xl shadow-sm">
      <h2 class="font-serif text-xl font-bold text-navy mb-3">Investment Advice &amp; Newsletters</h2>
      <p class="text-gray-600 text-sm leading-relaxed mb-4">Periodic newsletters covering investment strategies, market insights, and financial planning topics written by Eric J. Linger.</p>
      <p class="text-sm text-gray-400 italic">Newsletter PDFs will be listed here.</p>
    </div>
    <div class="p-6 border border-gray-100 rounded-xl shadow-sm">
      <h2 class="font-serif text-xl font-bold text-navy mb-3">Letter of Agreement</h2>
      <p class="text-gray-600 text-sm leading-relaxed mb-4">Our standard client agreement outlines the terms of our engagement, compensation structure, and fiduciary commitment.</p>
      <p class="text-sm text-gray-400 italic">Document available upon request.</p>
    </div>
    <div class="p-6 border border-gray-100 rounded-xl shadow-sm">
      <h2 class="font-serif text-xl font-bold text-navy mb-3">Partner Links</h2>
      <p class="text-gray-600 text-sm leading-relaxed mb-4">We work with a network of investment professionals to develop your financial plan and manage your investments. Useful links to our trusted partners.</p>
      <ul class="text-sm text-navy space-y-2 mt-4">
        <li><a href="https://www.schwab.com" class="hover:text-gold transition-colors" target="_blank" rel="noopener">Charles Schwab (My Account) →</a></li>
      </ul>
    </div>
  </section>
</Layout>
