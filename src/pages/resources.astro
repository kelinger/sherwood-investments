<Layout title="Resources" description="Investment newsletters, the Letter of Agreement, and partner links from Sherwood Investments.">
  <div class="relative text-white py-16 px-4 text-center" style="background: linear-gradient(rgba(19,40,64,0.78), rgba(19,40,64,0.78)), url('/banners/resources.jpg') center/cover no-repeat;">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold uppercase tracking-widest text-sm font-semibold mb-2">Stay Informed</p>
      <h1 class="font-serif text-4xl font-bold">Resources</h1>
    </div>
  </div>

  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      <div class="p-6 border border-gray-100 rounded-xl shadow-sm">
        <h2 class="font-serif text-xl font-bold text-navy mb-3">Documents</h2>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">Client agreements, disclosure documents, and regulatory filings.</p>
        <ul class="text-sm space-y-3 mt-4">
          <li><a href="/documents/letter-of-agreement.pdf" class="text-navy hover:text-gold transition-colors flex items-center gap-2" target="_blank">📄 Letter of Agreement</a></li>
          <li><a href="/documents/adv2.pdf" class="text-navy hover:text-gold transition-colors flex items-center gap-2" target="_blank">📄 ADV Part 2 Disclosure</a></li>
          <li><a href="/documents/privacy-statement.pdf" class="text-navy hover:text-gold transition-colors flex items-center gap-2" target="_blank">📄 Privacy Statement</a></li>
        </ul>
      </div>
      <div class="p-6 border border-gray-100 rounded-xl shadow-sm md:col-span-2">
        <h2 class="font-serif text-xl font-bold text-navy mb-3">Partner Links</h2>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">We work with a network of investment professionals to develop your financial plan and manage your investments.</p>
        <ul class="text-sm text-navy space-y-2 mt-4">
          <li><a href="https://www.schwab.com" class="hover:text-gold transition-colors" target="_blank" rel="noopener">Charles Schwab (My Account) →</a></li>
        </ul>
      </div>
    </div>

    <div>
      <h2 class="font-serif text-3xl font-bold text-navy mb-2">Investment Advice &amp; Newsletters</h2>
      <p class="text-gray-600 mb-8">Periodic newsletters covering investment strategies, market insights, and financial planning topics written by Eric J. Linger.</p>
      <div class="space-y-2">
        {newsletters.map(n => (
          <a href={n.slug} class="flex items-center justify-between gap-4 p-4 border border-gray-100 rounded-lg hover:border-gold hover:bg-amber-50 transition-colors group">
            <span class="text-navy font-medium group-hover:text-gold transition-colors">{n.title}</span>
            <span class="text-gray-400 text-sm shrink-0">{n.date}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
